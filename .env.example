# Server
PORT=3001
NODE_ENV=development

# MongoDB Atlas — replace with your connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/happy-pet-handbook?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend (CORS) — comma-separated if multiple
# Dev also allows any http://localhost:* / http://127.0.0.1:* automatically
CORS_ORIGIN=http://localhost:5173,https://paws-path.netlify.app,https://happy-pet-handbook-fe-five.vercel.app

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Cloudinary (avatars + optional guide PDF backup)
# Note: Free Cloudinary often returns 401 for public PDF delivery.
# Guides are served from this API at /api/guides/:slug/file (local uploads/).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Swagger docs basic auth (browser login popup)
SWAGGER_USER=admin
SWAGGER_PASSWORD=ok

# Optional — show production server in Swagger when running locally
# Render sets RENDER_EXTERNAL_URL automatically when deployed
PUBLIC_URL=https://happy-pet-hanhbook-be.onrender.com
